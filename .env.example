# Copy to .env. Never commit the populated file.
KINDRED_ENV=development
KINDRED_HOST=0.0.0.0
KINDRED_PORT=8000
KINDRED_DATABASE_PATH=./data/kindred.db
KINDRED_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
KINDRED_DAEMON_ENABLED=true
KINDRED_DAEMON_INTERVAL_SECONDS=60
KINDRED_TIMEZONE=America/Chicago

# Local authentication. Change these before exposing Kindred to a LAN or tailnet.
KINDRED_AUTH_ENABLED=true
KINDRED_ADMIN_USERNAME=admin
KINDRED_ADMIN_PASSWORD=change-me-now
KINDRED_SESSION_SECRET=replace-with-a-long-random-string
KINDRED_SESSION_HOURS=168

# Local model backend (default)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:1b
LLAMACPP_BASE_URL=http://127.0.0.1:8080

# Optional local semantic lore retrieval. Requires an Ollama embedding model.
KINDRED_EMBEDDINGS_ENABLED=false
KINDRED_EMBEDDINGS_PROVIDER=ollama
KINDRED_EMBEDDINGS_MODEL=all-minilm
KINDRED_EMBEDDINGS_DIMENSIONS=0

# Optional OpenAI-compatible cloud backend. Cloud use is opt-in per character.
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4.1-mini
KINDRED_CLOUD_DRY_RUN=true

# Optional Web Push. Generate values with scripts/generate_vapid_keys.py.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Optional docker/compose.domain.yml values.
KINDRED_DOMAIN=kindred.example.com
ACME_EMAIL=admin@example.com
