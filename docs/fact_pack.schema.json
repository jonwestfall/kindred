{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kindred.local/schemas/kindred.fact_pack.v1.json",
  "title": "Kindred Fact Pack",
  "description": "Portable lore/fact file imported by Kindred for lightweight retrieval augmented generation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "name", "facts"],
  "properties": {
    "schema": {
      "const": "kindred.fact_pack.v1"
    },
    "exported_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "default": ""
    },
    "source_title": {
      "type": "string",
      "maxLength": 500,
      "default": ""
    },
    "source_author": {
      "type": "string",
      "maxLength": 300,
      "default": ""
    },
    "source_reference": {
      "type": "string",
      "maxLength": 1000,
      "default": ""
    },
    "facts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["content"],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 300,
            "default": ""
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4000
          },
          "keywords": {
            "type": "array",
            "maxItems": 24,
            "items": {
              "type": "string"
            },
            "default": []
          },
          "tags": {
            "type": "array",
            "maxItems": 24,
            "items": {
              "type": "string"
            },
            "default": []
          },
          "source_reference": {
            "type": "string",
            "maxLength": 1000,
            "default": ""
          },
          "weight": {
            "type": "number",
            "minimum": 0.1,
            "maximum": 5,
            "default": 1
          }
        }
      }
    }
  }
}
